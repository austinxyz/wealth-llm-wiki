# ========================================
# 家庭财富知识库 - 环境变量配置
# ========================================
# 复制此文件为 .env 并修改为实际值
# cp .env.example .env

# --- 网络配置 ---

# NAS 的内网 IP（只绑定此 IP，不暴露到 0.0.0.0）
BIND_IP=10.0.0.20

# Web 访问端口
WEB_PORT=8080

# --- 内容目录路径 ---
# 这三个路径必须是 NAS 上的绝对路径
# 根据你的 NAS 目录结构修改

# 原始资料目录（raw_material）
RAW_MATERIAL_PATH=/volume1/sync/wealth/raw_material

# Wiki 知识库目录
WIKI_PATH=/volume1/sync/wealth/wiki

# 个人策略目录（output）
OUTPUT_PATH=/volume1/sync/wealth/output

# --- 时区 ---
TZ=Asia/Shanghai
